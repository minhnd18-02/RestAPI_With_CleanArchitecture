            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "passwordHash": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "description": "JWT Authorization header using the Bearer scheme. \n\nEnter your token in the text input below. \n\nExample: '12345abcde'",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
